  "workflow_repair_policy": "default",
  "review_policy": {
    "test_to_code_ratio": {
      "min_ratio": 0.5,
      "accept_doctest": false,
      "template_overrides": {
        "orchestrator-self-repair": {
          "min_ratio": 0.0,
          "accept_doctest": true
        }
      }
    },
    "validation_evidence_required": {
      "enabled": true,
      "accept_doctest": true,
      "risk_based": true,
      "template_overrides": {}
    }
  },
  "synthetic_canary": {
    "enabled": false,
    "project": "example-project",
    "interval_hours": 6,
    "success_sla_hours": 24,
    "max_frontier_age_hours": 2,
    "summary": "Synthetic workflow canary",
    "roadmap_entry_id": "R-021-CANARY",
    "roadmap_title": "Synthetic workflow canary",
    "roadmap_body": "Goal: validate the orchestrator end-to-end path with one tiny, safe slice."
  },
  "environment_health": {
    "cache_sec": 60,
    "required_launchd_labels": [
      "planner",
