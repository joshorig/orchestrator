# Shared non-secret runtime environment for every orchestrator runner.
# Copy to config/runtime.env on each host and keep the live file untracked.

DEV_ROOT=/Volumes/devssd
JAVA_HOME=/opt/homebrew/opt/openjdk@21/libexec/openjdk.jdk/Contents/Home
GRADLE_USER_HOME=/Volumes/devssd/.gradle
PATH=/opt/homebrew/opt/openjdk@21/bin:/Users/devmini/.local/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin
