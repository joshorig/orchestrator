flowchart TD;
    Start[Start] -- "always" --> ReadMod[Read: locate affected <module>];
    ReadMod -- "module mapped" --> ReadHot[Read: map <hot_path> boundary];
    ReadHot -- "boundary mapped" --> ReadInv[Read: list in-scope invariants];
    ReadInv -- "invariants listed" --> CheckBaseline[Check: baseline smoke green on unmodified worktree];
    CheckBaseline -- "baseline red" --> ExitBaseline[Exit: BRAID_TOPOLOGY_ERROR baseline_red];
    CheckBaseline -- "baseline green" --> Sketch[Read: sketch <operator> change];
    Sketch -- "sketch done" --> Draft[Draft: implement <operator> change];
    Draft -- "draft ready" --> RunUnit[Run: focused tests for <module>];
    RunUnit -- "tests fail" --> ReviseCheck1[Revise: fix draft before gates];
    ReviseCheck1 -- "retry" --> Draft;
    RunUnit -- "tests pass" --> CheckAlloc[Check: zero alloc on hot path];
    CheckAlloc -- "alloc found" --> ReviseCheck2[Revise: remove hot-path alloc];
    ReviseCheck2 -- "retry" --> Draft;
    CheckAlloc -- "alloc clean" --> CheckGc[Check: no gc hiccups above jmh smoke gate];
    CheckGc -- "gc regressed" --> ReviseCheck3[Revise: tune perf-sensitive path];
    ReviseCheck3 -- "retry" --> Draft;
    CheckGc -- "gc clean" --> CheckJava[Check: Java 21 source/target];
    CheckJava -- "java mismatch" --> ReviseCheck4[Revise: restore Java 21 compat];
    ReviseCheck4 -- "retry" --> Draft;
    CheckJava -- "java clean" --> CheckIpc[Check: IPC matches in-proc semantics];
    CheckIpc -- "ipc mismatch" --> ReviseCheck5[Revise: align IPC semantics];
    ReviseCheck5 -- "retry" --> Draft;
    CheckIpc -- "ipc aligned" --> CheckOrder[Check: per-key in-order in guaranteed mode];
    CheckOrder -- "order broke" --> ReviseCheck6[Revise: restore guaranteed ordering];
    ReviseCheck6 -- "retry" --> Draft;
    CheckOrder -- "order preserved" --> CheckFrag[Check: fragmentation reassembly intact];
    CheckFrag -- "fragmentation broke" --> ReviseCheck7[Revise: restore fragment handling];
    ReviseCheck7 -- "retry" --> Draft;
    CheckFrag -- "reassembly intact" --> CheckConf[Check: conformanceSuite green];
    CheckConf -- "conformance fails" --> ReviseCheck8[Revise: fix conformance drift];
    ReviseCheck8 -- "retry" --> Draft;
    CheckConf -- "conformance green" --> CheckJmh[Check: jmhQuickcheck delta within noise];
    CheckJmh -- "delta high" --> ReviseCheck9[Revise: reduce benchmark delta];
    ReviseCheck9 -- "retry" --> Draft;
    CheckJmh -- "delta ok" --> End[End];
