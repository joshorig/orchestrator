flowchart TD;
Start[Start] --> Read[Read last 10 entries];
Read --> Style[Extract style pattern];
Style --> Locate[Locate append marker];
Locate --> Summarize[Summarize task done];
Summarize --> Draft[Draft bullet entry];
Draft --> C1{Check: append only};
C1 -- fail --> Revise[Revise draft];
C1 -- pass --> C2{Check: new entry below marker};
C2 -- fail --> Revise;
C2 -- pass --> C3{Check: entry under 240 chars};
C3 -- fail --> Revise;
C3 -- pass --> C4{Check: includes date YYYY-MM-DD};
C4 -- fail --> Revise;
C4 -- pass --> C5{Check: no secrets no credentials};
C5 -- fail --> Revise;
C5 -- pass --> C6{Check: no prose speculation};
C6 -- fail --> Revise;
C6 -- pass --> C7{Check: file stays valid markdown};
C7 -- fail --> Revise;
C7 -- pass --> Write[Append entry to file];
Revise -- retry --> Draft;
Write --> Verify{Check: bytes before unchanged};
Verify -- fail --> Revise;
Verify -- pass --> End[End];