flowchart TD;
    Start[Start] -- "always" --> ReadTarget[Read: inspect task target];
    ReadTarget -- "target known" --> Branch{Target kind};
    Branch -- "recent work" --> ReadRecent[Read: inspect latest memory entries];
    Branch -- "roadmap" --> ReadRoadmap[Read: inspect target roadmap entry];
    ReadRecent -- "entries loaded" --> DraftEntry[Draft: append one historian entry];
    DraftEntry -- "draft ready" --> CheckAppend[Check: single entry append];
    CheckAppend -- "append drifted" --> ReviseCheck1[Revise: narrow append scope];
    ReviseCheck1 -- "retry" --> DraftEntry;
    CheckAppend -- "append bounded" --> CheckRewrite[Check: no rewrite of prior entries];
    CheckRewrite -- "rewrite found" --> ReviseCheck2[Revise: preserve prior lines];
    ReviseCheck2 -- "retry" --> DraftEntry;
    CheckRewrite -- "history preserved" --> RunWrite[Run: write historian append];
    RunWrite -- "write complete" --> End[End];
    ReadRoadmap -- "entry loaded" --> DraftFlip[Draft: flip target status line];
    DraftFlip -- "draft ready" --> CheckFlip[Check: roadmap single-line flip only];
    CheckFlip -- "flip drifted" --> ReviseCheck3[Revise: limit roadmap mutation];
    ReviseCheck3 -- "retry" --> DraftFlip;
    CheckFlip -- "flip bounded" --> CheckDone[Check: roadmap noop if already done];
    CheckDone -- "noop violated" --> ReviseCheck4[Revise: preserve done entry];
    ReviseCheck4 -- "retry" --> DraftFlip;
    CheckDone -- "noop preserved" --> CheckBytes[Check: roadmap byte preservation];
    CheckBytes -- "bytes drifted" --> ReviseCheck5[Revise: restore untouched bytes];
    ReviseCheck5 -- "retry" --> DraftFlip;
    CheckBytes -- "bytes preserved" --> RunFlip[Run: write roadmap update];
    RunFlip -- "write complete" --> End;
