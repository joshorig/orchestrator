flowchart TD;
Start[Start] --> Enum[Enumerate diff];
Enum --> Classify{Classify risk};
Classify -->|"secrets"| SecretScan[Inspect secrets];
Classify -->|"auth"| AuthScan[Inspect auth];
Classify -->|"shell-file"| ShellScan[Inspect shell file ops];
Classify -->|"network-config"| NetScan[Inspect trust config];
Classify -->|"other"| General[Inspect general];
SecretScan --> C1;
AuthScan --> C2;
ShellScan --> C3;
NetScan --> C4;
General --> C5;
C1[Check: no secrets leaked] -->|"pass"| C2;
C1 -->|"fail"| RC[RequestChange: collect];
C2[Check: auth boundary preserved] -->|"pass"| C3;
C2 -->|"fail"| RC;
C3[Check: shell or file ops safe] -->|"pass"| C4;
C3 -->|"fail"| RC;
C4[Check: network trust explicit] -->|"pass"| C5;
C4 -->|"fail"| RC;
C5[Check: config does not expose local paths] -->|"pass"| Verdict;
C5 -->|"fail"| RC;
RC --> Verdict{Any change requested};
Verdict -->|"yes"| Emit[Emit change list];
Verdict -->|"no"| Approve[Approve diff];
Emit --> End[End];
Approve --> End;
