flowchart TD;
    Start[Start] -- "always" --> ReadArea[Read: locate affected <runtime_area>];
    ReadArea -- "area mapped" --> ReadInv[Read: list dag invariants];
    ReadInv -- "invariants listed" --> Draft[Draft: implement <node> change];
    Draft -- "draft ready" --> RunTests[Run: focused runtime tests];
    RunTests -- "tests fail" --> ReviseCheck1[Revise: fix draft and tests];
    ReviseCheck1 -- "retry" --> Draft;
    RunTests -- "tests pass" --> CheckBase[Check: baseline smoke green];
    CheckBase -- "baseline red" --> ReviseCheck2[Revise: restore clean baseline];
    ReviseCheck2 -- "retry" --> Draft;
    CheckBase -- "baseline green" --> CheckAlloc[Check: zero alloc on node traversal];
    CheckAlloc -- "alloc found" --> ReviseCheck3[Revise: remove traversal alloc];
    ReviseCheck3 -- "retry" --> Draft;
    CheckAlloc -- "alloc clean" --> CheckDag[Check: cycle-free DAG preserved];
    CheckDag -- "cycle found" --> ReviseCheck4[Revise: restore DAG shape];
    ReviseCheck4 -- "retry" --> Draft;
    CheckDag -- "dag clean" --> CheckPar[Check: parallelism contract honored];
    CheckPar -- "contract broke" --> ReviseCheck5[Revise: restore parallel semantics];
    ReviseCheck5 -- "retry" --> Draft;
    CheckPar -- "contract held" --> CheckConf[Check: conformance tests green];
    CheckConf -- "conformance fails" --> ReviseCheck6[Revise: fix conformance drift];
    ReviseCheck6 -- "retry" --> Draft;
    CheckConf -- "conformance green" --> End[End];
