flowchart TD;
    Start[Start] -- "always" --> ReadSurface[Read: inspect <component> surface];
    ReadSurface -- "surface mapped" --> ReadProps[Read: inspect typed <props>];
    ReadProps -- "props mapped" --> Draft[Draft: implement <component> change];
    Draft -- "draft ready" --> RunUi[Run: focused UI validation];
    RunUi -- "validation fails" --> ReviseCheck1[Revise: fix UI draft];
    ReviseCheck1 -- "retry" --> Draft;
    RunUi -- "validation passes" --> CheckType[Check: typecheck green];
    CheckType -- "typecheck red" --> ReviseCheck2[Revise: fix typing regressions];
    ReviseCheck2 -- "retry" --> Draft;
    CheckType -- "typecheck green" --> CheckLint[Check: lint green];
    CheckLint -- "lint red" --> ReviseCheck3[Revise: fix lint regressions];
    ReviseCheck3 -- "retry" --> Draft;
    CheckLint -- "lint green" --> CheckVitest[Check: vitest green];
    CheckVitest -- "vitest red" --> ReviseCheck4[Revise: fix vitest regressions];
    ReviseCheck4 -- "retry" --> Draft;
    CheckVitest -- "vitest green" --> CheckPw[Check: Playwright smoke+a11y green];
    CheckPw -- "playwright red" --> ReviseCheck5[Revise: fix smoke and a11y];
    ReviseCheck5 -- "retry" --> Draft;
    CheckPw -- "playwright green" --> CheckContract[Check: contract snapshot unchanged];
    CheckContract -- "snapshot drift" --> ReviseCheck6[Revise: restore UI contract];
    ReviseCheck6 -- "retry" --> Draft;
    CheckContract -- "snapshot clean" --> End[End];
