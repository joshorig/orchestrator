flowchart TD;
    Start[Start] -- "always" --> Enum[Enumerate diff files];
    Enum -- "files listed" --> Loop[For each file];
    Loop -- "next file" --> Classify{Classify file};
    Classify -- "ui" --> UiPath[Inspect ui surface delta];
    Classify -- "api" --> ApiPath[Inspect api contract delta];
    Classify -- "runtime" --> RuntimePath[Inspect runtime path delta];
    Classify -- "test" --> TestPath[Inspect test coverage delta];
    Classify -- "docs or config" --> DocCfgPath[Inspect docs and config delta];
    UiPath -- "ui mapped" --> Next{More files};
    ApiPath -- "api mapped" --> Next;
    RuntimePath -- "runtime mapped" --> Next;
    TestPath -- "tests mapped" --> Next;
    DocCfgPath -- "docs mapped" --> Next;
    Next -- "yes" --> Loop;
    Next -- "no" --> Check1[Check: diff minimal];
    Check1 -- "fail" --> Request[RequestChange: collect findings];
    Check1 -- "pass" --> Check2[Check: runtime invariants preserved];
    Check2 -- "fail" --> Request;
    Check2 -- "pass" --> Check3[Check: api or ui contract preserved];
    Check3 -- "fail" --> Request;
    Check3 -- "pass" --> Check4[Check: tests and smoke cover change];
    Check4 -- "fail" --> Request;
    Check4 -- "pass" --> Check5[Check: docs aligned];
    Check5 -- "fail" --> Request;
    Check5 -- "pass" --> Check6[Check: no secrets or unsafe config drift];
    Check6 -- "fail" --> Request;
    Check6 -- "pass" --> Verdict{Any change requested};
    Request -- "findings collected" --> Verdict;
    Verdict -- "yes" --> Emit[Emit change list];
    Verdict -- "no" --> Approve[Approve diff];
    Emit -- "finalize" --> End[End];
    Approve -- "finalize" --> End;
