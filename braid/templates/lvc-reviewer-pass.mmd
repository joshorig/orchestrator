flowchart TD;
Start[Start review] --> Enum[Enumerate diff files];
Enum --> Loop[For each file];
Loop --> Classify{Classify file};
Classify -->|src| SrcPath[Inspect src hunk];
Classify -->|test| TestPath[Inspect test hunk];
Classify -->|docs| DocPath[Inspect docs hunk];
Classify -->|config| CfgPath[Inspect config hunk];
SrcPath --> ApiCheck{Touches api package};
ApiCheck -->|yes| ApiFlag[Mark API surface change];
ApiCheck -->|no| HotPath{Hot path code};
ApiFlag --> HotPath;
HotPath -->|yes| InvScan[Scan for alloc boxing new];
HotPath -->|no| LogicScan[Scan logic delta];
InvScan --> LogicScan;
TestPath --> LogicScan;
DocPath --> DocScan[Note doc target];
CfgPath --> CfgScan[Note config target];
LogicScan --> Next{More files};
DocScan --> Next;
CfgScan --> Next;
Next -->|yes| Loop;
Next -->|no| C1;
C1[Check: diff minimal] -->|pass| C2;
C1 -->|fail| RC[RequestChange: collect];
C2[Check: invariants preserved] -->|pass| C3;
C2 -->|fail| RC;
C3[Check: tests exist for change] -->|pass| C4;
C3 -->|fail| RC;
C4[Check: no dead code left] -->|pass| C5;
C4 -->|fail| RC;
C5[Check: no TODO XXX FIXME introduced] -->|pass| C6;
C5 -->|fail| RC;
C6[Check: public API not silently broken] -->|pass| C7;
C6 -->|fail| RC;
C7[Check: docs aligned] -->|pass| C8;
C7 -->|fail| RC;
C8[Check: no secrets in diff] -->|pass| Verdict;
C8 -->|fail| RC;
RC --> Verdict{Any change requested};
Verdict -->|yes| Emit[Emit change list];
Verdict -->|no| Approve[Approve diff];
Emit --> End[End BRAID_OK];
Approve --> End;