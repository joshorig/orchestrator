flowchart TD;
    Start[Start] -- "if entered" --> ReadFlag[Read conflict flag];
    ReadFlag -- "if flag read" --> ReadComments[Read comment list];
    ReadComments -- "if comments loaded" --> ReadChecks[Read failed check list];
    ReadChecks -- "if checks loaded" --> Check0[Check: baseline smoke green];
    Check0 -- "if baseline red" --> ExitBaseline[Exit: BRAID_TOPOLOGY_ERROR baseline_red];
    Check0 -- "if baseline green" --> Route[Route by input signals];
    Route -- "if conflicts present" --> Rebase[Rebase onto origin/<base>];
    Route -- "if no conflicts and checks failed" --> PickCheck[Pick next failed <check>];
    Route -- "if no conflicts and no checks and comments" --> PickComment[Pick next <comment>];
    Route -- "if nothing actionable" --> Join[Join fix branches];
    Rebase -- "if conflict hunks present" --> Resolve[Resolve <conflict_hunk>];
    Resolve -- "if hunk resolved" --> StageConflict[Stage resolved <file>];
    StageConflict -- "if more hunks" --> Resolve;
    StageConflict -- "if rebase continues" --> Rebase;
    Rebase -- "if rebase clean" --> CommitConflict[Commit under agent identity];
    CommitConflict -- "if committed" --> CheckFailuresGate[Gate to failed check loop];
    CheckFailuresGate -- "if checks failed" --> PickCheck;
    CheckFailuresGate -- "if no checks failed" --> CommentsGate[Gate to comment loop];
    PickCheck -- "if <check> selected" --> DraftCheckFix[Draft <fix> for <check>];
    PickCheck -- "if <check> stale rerun green" --> SkipStale[Skip stale <check>];
    SkipStale -- "if more checks failed" --> PickCheck;
    SkipStale -- "if checks clear" --> CommentsGate;
    DraftCheckFix -- "if alloc gate check" --> AllocGateDecision[Decide alloc gate strategy];
    DraftCheckFix -- "if non-alloc check" --> ApplyCheckFix[Apply <fix> to <file>];
    AllocGateDecision -- "if preserve true latency" --> PreserveTrue[Keep true restore-latency measurement];
    AllocGateDecision -- "if proxy required" --> SwapProxy[Swap to low-alloc proxy benchmark];
    PreserveTrue -- "if path chosen" --> ApplyCheckFix;
    SwapProxy -- "if path chosen" --> ApplyCheckFix;
    ApplyCheckFix -- "if applied" --> CommitCheckFix[Commit under agent identity];
    CommitCheckFix -- "if more checks failed" --> PickCheck;
    CommitCheckFix -- "if checks clear" --> CommentsGate;
    CommentsGate -- "if comments remain" --> PickComment;
    CommentsGate -- "if no comments" --> Join;
    PickComment -- "if <comment> selected" --> Classify[Classify <comment> actionable or rationale];
    Classify -- "if code change needed" --> DraftFix[Draft <fix> for <comment>];
    Classify -- "if rationale only" --> RecordRationale[Record rationale in commit msg];
    DraftFix -- "if fix drafted" --> ApplyFix[Apply <fix> to <file>];
    ApplyFix -- "if applied" --> CommitFix[Commit under agent identity];
    RecordRationale -- "if rationale recorded" --> CommitFix;
    CommitFix -- "if more comments" --> PickComment;
    CommitFix -- "if comments exhausted" --> Join;
    Join -- "if joined" --> Check1[Check: conflicts resolved];
    Check1 -- "if markers remain" --> Revise[Revise: reopen failed branch];
    Check1 -- "if tree clean" --> Check2[Check: each comment addressed];
    Check2 -- "if comment unaddressed" --> Revise;
    Check2 -- "if all addressed" --> Check3[Check: post-fix smoke green];
    Check3 -- "if smoke red" --> Revise;
    Check3 -- "if smoke green" --> Check4[Check: no new files outside scope];
    Check4 -- "if scope creep" --> Revise;
    Check4 -- "if scope intact" --> Check5[Check: commit authored under agent identity];
    Check5 -- "if author mismatch" --> Revise;
    Check5 -- "if identity ok" --> Emit[Emit BRAID_OK];
    Revise -- "if conflict failure" --> Rebase;
    Revise -- "if check failure" --> PickCheck;
    Revise -- "if comment failure" --> PickComment;
    Revise -- "if unreachable" --> ExitUnreachable[Exit: BRAID_TOPOLOGY_ERROR graph_unreachable];
    Revise -- "if malformed" --> ExitMalformed[Exit: BRAID_TOPOLOGY_ERROR graph_malformed];
    Emit -- "if emitted" --> End[End];
    ExitBaseline -- "if exited" --> End;
    ExitUnreachable -- "if exited" --> End;
    ExitMalformed -- "if exited" --> End;
