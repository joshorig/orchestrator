flowchart TD;
    Start[Start] -- "always" --> ReadFindings[Read: reviewer findings];
    ReadFindings -- "findings parsed" --> ReadDiff[Read: current diff];
    ReadDiff -- "diff parsed" --> LocateFiles[Locate: affected files];
    LocateFiles -- "files known" --> DraftPatch[Draft: requested fixes];
    DraftPatch -- "patch ready" --> ApplyPatch[Apply: worktree edits];
    ApplyPatch -- "edits saved" --> Check1[Check: reviewer findings addressed];
    Check1 -- "findings still open" --> ReviseCheck1[Revise: close reviewer gaps];
    Check1 -- "findings covered" --> Check2[Check: no regressions introduced];
    ReviseCheck1 -- "patch revised" --> DraftPatch;
    Check2 -- "regression found" --> ReviseCheck2[Revise: restore invariant];
    Check2 -- "no regression" --> Check3[Check: existing tests still pass];
    ReviseCheck2 -- "invariant restored" --> ApplyPatch;
    Check3 -- "tests fail" --> ReviseCheck3[Revise: repair failing path];
    Check3 -- "tests pass" --> Check4[Check: new surface covered];
    ReviseCheck3 -- "test issue fixed" --> ApplyPatch;
    Check4 -- "coverage missing" --> ReviseCheck4[Revise: add targeted coverage];
    Check4 -- "coverage adequate" --> Check5[Check: commit exists];
    ReviseCheck4 -- "coverage added" --> ApplyPatch;
    Check5 -- "no commit-ready diff" --> ReviseCheck5[Revise: finalize commitable state];
    Check5 -- "commit ready" --> End[End];
    ReviseCheck5 -- "state finalized" --> ApplyPatch;
