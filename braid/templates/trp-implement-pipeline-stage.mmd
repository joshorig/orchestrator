flowchart TD;
    Start[Start] -- "always" --> ReadStage[Read: locate affected <stage>];
    ReadStage -- "stage mapped" --> ReadContract[Read: inspect <contract> boundaries];
    ReadContract -- "contract mapped" --> Draft[Draft: implement <stage> change];
    Draft -- "draft ready" --> RunTests[Run: focused stage validation];
    RunTests -- "tests fail" --> ReviseCheck1[Revise: fix draft and tests];
    ReviseCheck1 -- "retry" --> Draft;
    RunTests -- "tests pass" --> CheckBase[Check: baseline smoke green];
    CheckBase -- "baseline red" --> ReviseCheck2[Revise: restore smoke baseline];
    ReviseCheck2 -- "retry" --> Draft;
    CheckBase -- "baseline green" --> CheckContract[Check: contract snapshot unchanged];
    CheckContract -- "snapshot drift" --> ReviseCheck3[Revise: restore contract shape];
    ReviseCheck3 -- "retry" --> Draft;
    CheckContract -- "snapshot clean" --> CheckJmh[Check: jmhSmokeAll delta within noise];
    CheckJmh -- "delta high" --> ReviseCheck4[Revise: reduce stage regression];
    ReviseCheck4 -- "retry" --> Draft;
    CheckJmh -- "delta ok" --> CheckAlloc[Check: zero alloc on stage hot-path];
    CheckAlloc -- "alloc found" --> ReviseCheck5[Revise: remove stage alloc];
    ReviseCheck5 -- "retry" --> Draft;
    CheckAlloc -- "alloc clean" --> End[End];
