flowchart TD;
Start[Start] --> Enum[Enumerate diff];
Enum --> Scope[Inspect task scope];
Scope --> C1;
C1[Check: scope matches task] -->|"pass"| C2;
C1 -->|"fail"| RC[RequestChange: collect];
C2[Check: decisions still respected] -->|"pass"| C3;
C2 -->|"fail"| RC;
C3[Check: state transitions remain sound] -->|"pass"| C4;
C3 -->|"fail"| RC;
C4[Check: docs and memory aligned] -->|"pass"| C5;
C4 -->|"fail"| RC;
C5[Check: no hidden policy drift] -->|"pass"| Verdict;
C5 -->|"fail"| RC;
RC --> Verdict{Any change requested};
Verdict -->|"yes"| Emit[Emit change list];
Verdict -->|"no"| Approve[Approve diff];
Emit --> End[End];
Approve --> End;
