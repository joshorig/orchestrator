<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.devmini.orchestrator.dashboard-feed</string>
  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>-c</string>
    <string>set -a; source /Volumes/devssd/orchestrator/config/runtime.env; set +a; exec /opt/homebrew/bin/python3 /Volumes/devssd/orchestrator/bin/dashboard_feed.py</string>
  </array>
  <key>WorkingDirectory</key>
  <string>/Volumes/devssd/orchestrator</string>
  <key>StartInterval</key>
  <integer>5</integer>
  <key>RunAtLoad</key>
  <true/>
  <key>StandardOutPath</key>
  <string>/Users/devmini/Library/Logs/devmini/dashboard-feed.stdout.log</string>
  <key>StandardErrorPath</key>
  <string>/Users/devmini/Library/Logs/devmini/dashboard-feed.stderr.log</string>
</dict>
</plist>
